# Contoh environment variable untuk IDX Stock Screener
# Salin file ini menjadi .env pada pengembangan lokal, lalu isi nilainya.
# Di Hostinger, isi variable yang sama melalui panel (Python App -> Environment variables).

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=idx_screener
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# --- Aplikasi ---
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Zona waktu referensi bursa (tetap Asia/Jakarta kecuali diperlukan lain)
MARKET_TIMEZONE=Asia/Jakarta

# Interval pengambilan data dalam menit (default 15)
FETCH_INTERVAL_MINUTES=15

# Jumlah bar historis minimal yang diminta dari yfinance (untuk mendukung EMA_200)
HISTORY_BAR_COUNT=260

# Timeout per-ticker ke yfinance dalam detik
YFINANCE_TIMEOUT_SECONDS=30

# Concurrency maksimum untuk pemanggilan yfinance per siklus
FETCH_MAX_CONCURRENCY=8

# Origin yang diizinkan oleh CORS (pisahkan dengan koma jika lebih dari satu)
CORS_ALLOW_ORIGINS=http://localhost:5173

# Mode aplikasi: development | production
APP_ENV=development
